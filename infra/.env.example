# Optional: enable Cognito JWT authorizer for API Gateway
# Set these variables in your shell before `cdk synth/deploy`.

# JWT issuer example:
# https://cognito-idp.eu-central-1.amazonaws.com/eu-central-1_XXXXXXXXX
WCC_COGNITO_JWT_ISSUER=

# Cognito app client id(s), comma-separated
WCC_COGNITO_JWT_AUDIENCE=

# Lambda runtime auth mode when JWT authorizer is not enabled (none | google-jwt | trust-apigw)
WCC_API_AUTH_MODE=none

# Optional local/testing Google ids (comma-separated).
# The first id is also reused for frontend production build when
# NEXT_PUBLIC_GOOGLE_CLIENT_ID is not set explicitly.
WCC_GOOGLE_CLIENT_IDS=
