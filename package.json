{
  "name": "witcher-cc-starter",
  "private": true,
  "workspaces": [
    "cloud/*"
  ],
  "scripts": {
    "setup": "npm install",
    "dev": "npm-run-all -p dev:api dev:web",
    "dev:api": "npm --workspace @wcc/cloud-api run dev",
    "dev:web": "npm --workspace @wcc/cloud-web run dev",
    "build": "npm-run-all -s build:prepare-sql build:api build:web",
    "build:prepare-sql": "node scripts/prepare-deploy-sql.mjs",
    "build:api": "npm --workspace @wcc/cloud-api run build",
    "build:web": "npm --workspace @wcc/cloud-web run build",
    "deploy": "npm --workspace @wcc/infra run deploy",
    "lint": "echo \"(add ESLint later)\"",
    "format": "echo \"(add Prettier later)\""
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
